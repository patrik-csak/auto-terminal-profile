{
  "name": "auto-terminal-profile",
  "version": "7.0.1",
  "description": "Automatically switch macOS Terminal profile when system dark / light mode changes",
  "keywords": [
    "macos",
    "terminal",
    "light mode",
    "dark mode",
    "profile"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrik-csak/auto-terminal-profile.git"
  },
  "license": "MIT",
  "author": "Patrik Csak <p@trikcsak.com> (https://patrikcsak.com)",
  "type": "module",
  "bin": {
    "auto-terminal-profile": "cli.js"
  },
  "files": [
    "commands",
    "library"
  ],
  "scripts": {
    "_eslint": "eslint --cache --cache-strategy=content",
    "_knip": "knip --cache",
    "_prettier": "prettier --cache .",
    "format:check": "npm run _prettier -- --check",
    "format:fix": "npm run _prettier -- --write",
    "lint:check": "npm run _eslint",
    "lint:fix": "npm run _eslint -- --fix",
    "quality:check": "npm run format:check && npm run lint:check && npm run unused:check",
    "quality:fix": "npm run format:fix && npm run lint:fix && npm run unused:fix",
    "unused:check": "npm run _knip",
    "unused:fix": "npm run _knip -- --fix"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "commander": "^14.0.0",
    "conf": "^15.0.2",
    "consola": "^3.4.2",
    "dark-mode": "^5.0.0",
    "es-toolkit": "^1.45.1",
    "mac-terminal": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "eslint-plugin-package-json": "^0.91.0",
    "knip": "^6.3.1",
    "prettier": "^3.5.3",
    "xo": "^2.0.1"
  },
  "engines": {
    "node": ">=20.12.0 <=24"
  },
  "os": [
    "darwin"
  ]
}
