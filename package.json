{
  "name": "auto-terminal-profile",
  "version": "8.0.0",
  "description": "Automatically switch macOS Terminal profile when system dark / light mode changes",
  "keywords": [
    "macos",
    "terminal",
    "light mode",
    "dark mode",
    "profile"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrik-csak/auto-terminal-profile.git"
  },
  "license": "MIT",
  "author": "Patrik Csak <p@trikcsak.com> (https://patrikcsak.com)",
  "type": "module",
  "imports": {
    "#cli/actions": "./source/cli/actions/index.js",
    "#cli/commands": "./source/cli/commands/index.js",
    "#library": "./source/library/index.js",
    "#package-json": "./package.json"
  },
  "bin": {
    "auto-terminal-profile": "source/cli.js"
  },
  "files": [
    "source"
  ],
  "scripts": {
    "_eslint": "eslint --cache --cache-strategy=content",
    "_knip": "knip --cache",
    "_prettier": "prettier --cache .",
    "format:check": "npm run _prettier -- --check",
    "format:fix": "npm run _prettier -- --write",
    "lint:check": "npm run _eslint",
    "lint:fix": "npm run _eslint -- --fix",
    "quality:check": "npm run lint:check && npm run format:check && npm run unused:check",
    "quality:fix": "npm run lint:fix && npm run format:fix && npm run unused:fix",
    "test": "node --experimental-test-module-mocks --test",
    "test:coverage": "node --experimental-test-coverage --experimental-test-module-mocks --test",
    "unused:check": "npm run _knip",
    "unused:fix": "npm run _knip -- --fix"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "conf": "^15.0.2",
    "consola": "^3.4.2",
    "dark-mode": "^5.0.0",
    "mac-terminal": "^6.0.0",
    "ow": "^3.1.1"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-package-json": "^0.91.0",
    "knip": "^6.3.1",
    "prettier": "^3.5.3",
    "xo": "^2.0.1"
  },
  "engines": {
    "node": ">=22 <=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11.10.0"
    }
  },
  "os": [
    "darwin"
  ]
}
