{
  "name": "auto-terminal-profile",
  "version": "7.0.1",
  "description": "Automatically switch macOS Terminal profile when system dark / light mode changes",
  "keywords": [
    "macos",
    "terminal",
    "light mode",
    "dark mode",
    "profile"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrik-csak/auto-terminal-profile.git"
  },
  "license": "MIT",
  "author": "Patrik Csak <p@trikcsak.com> (https://patrikcsak.com)",
  "type": "module",
  "bin": {
    "auto-terminal-profile": "cli.js"
  },
  "scripts": {
    "eslint": "eslint --cache",
    "format:check": "npm run prettier -- --check",
    "format:fix": "npm run prettier -- --write",
    "lint:check": "npm run eslint",
    "lint:fix": "npm run eslint -- --fix",
    "prettier": "prettier --cache .",
    "quality:check": "npm run format:check && npm run lint:check && npm run unused:check",
    "quality:fix": "npm run format:fix && npm run lint:fix",
    "unused:check": "knip"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "commander": "^14.0.0",
    "conf": "^15.0.2",
    "consola": "^3.4.2",
    "dark-mode": "^5.0.0",
    "humanize-string": "^3.1.0",
    "mac-terminal": "^5.0.0",
    "ow": "^3.0.0",
    "p-memoize": "^8.0.0",
    "read-package-up": "^12.0.0"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "eslint-plugin-package-json": "^0.91.0",
    "knip": "^5.86.0",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "xo": "^2.0.1"
  },
  "engines": {
    "node": ">=20.12.0 <=24"
  },
  "os": [
    "darwin"
  ]
}
