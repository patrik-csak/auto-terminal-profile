{
  "name": "auto-terminal-profile",
  "version": "8.0.0",
  "description": "Automatically switch macOS Terminal profile when system dark / light mode changes",
  "keywords": [
    "macos",
    "terminal",
    "light mode",
    "dark mode",
    "profile"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrik-csak/auto-terminal-profile.git"
  },
  "license": "MIT",
  "author": "Patrik Csak <p@trikcsak.com> (https://patrikcsak.com)",
  "type": "module",
  "imports": {
    "#*": "./source/*/index.js",
    "#package-json": "./package.json"
  },
  "bin": {
    "auto-terminal-profile": "source/cli.js"
  },
  "files": [
    "source"
  ],
  "scripts": {
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:check": "eslint",
    "lint:fix": "eslint --fix",
    "quality:check": "npm run lint:check && npm run format:check && npm run unused:check",
    "quality:fix": "npm run lint:fix && npm run format:fix",
    "test": "node --experimental-test-module-mocks --test",
    "test:coverage": "npm run test -- --experimental-test-coverage",
    "unused:check": "knip"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "conf": "^15.0.2",
    "consola": "^3.4.2",
    "dark-mode": "^5.0.0",
    "mac-terminal": "^6.0.0",
    "ow": "^3.1.1"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.5.1",
    "eslint": "^10.0.3",
    "eslint-plugin-package-json": "^1.4.0",
    "knip": "^6.3.1",
    "prettier": "^3.5.3",
    "xo": "^3.0.2"
  },
  "engines": {
    "node": ">=22 <=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node"
    },
    "packageManager": {
      "name": "npm",
      "version": "^11.16"
    }
  },
  "os": [
    "darwin"
  ],
  "allowScripts": {
    "unrs-resolver": false
  }
}
